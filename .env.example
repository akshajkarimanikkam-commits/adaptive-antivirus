# Copy to .env.local (gitignored) for local dev.
# In production these are set via `vercel env add <NAME> production`.

# Resend transactional email — get a key at https://resend.com (free tier: 3,000 emails/month).
RESEND_API_KEY=re_your_api_key_here

# Display name + sender address used in the From header of the welcome email.
# Until a custom domain is verified in Resend, use the shared onboarding address.
RESEND_FROM="Adaptive Antivirus Team <onboarding@resend.dev>"
